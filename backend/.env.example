DATABASE_URL=sqlite:///./games.db
API_VERSION=v1
API_TITLE=Mini Game Platform API
API_DESCRIPTION=Backend API for HTML5 web game platform
ENVIRONMENT=development
STATIC_PATH=./games
# * = any origin (credentials disabled per CORS). Comma-separated allowlist enables credentials.
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
CORS_ORIGINS=*
# Optional: absolute path to frontend folder. Leave unset to use ../frontend from repo root.
# FRONTEND_PATH=
